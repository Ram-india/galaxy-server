# Copy to .env and fill in. Values marked optional have working fallbacks.

PORT=5000
MONGO_URI=mongodb+srv://user:password@cluster/dbname
JWT_SECRET=change-me-to-a-long-random-string

# Cloudinary — used for project images and profile photos
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Base URL of the admin panel. Password reset and invite links are built from
# this, so it must point at the deployed frontend in production.
# Optional — defaults to http://localhost:5173
CLIENT_URL=http://localhost:5173

# SMTP — optional. When any of HOST/USER/PASS is missing, reset and invite
# emails are printed to the server console instead of being sent, so local
# development works without mail credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="GPS Solar Admin <no-reply@yourdomain.com>"
